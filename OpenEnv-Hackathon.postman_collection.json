  "item": [
    {
      "name": "01 Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const j = pm.response.json();",
              "pm.test('Has status ok', function () {",
              "  pm.expect(j.status).to.eql('ok');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "02 Tasks",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/tasks",
          "host": ["{{base_url}}"],
          "path": ["tasks"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const j = pm.response.json();",
              "pm.test('Has tasks array', function () {",
              "  pm.expect(j.tasks).to.be.an('array');",
              "  pm.expect(j.tasks.length).to.be.above(2);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "03 Reset",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"task_id\": \"{{task_id}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/reset",
          "host": ["{{base_url}}"],
          "path": ["reset"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const j = pm.response.json();",
              "pm.test('Reset payload has observation', function () {",
              "  pm.expect(j).to.have.property('observation');",
              "  pm.expect(j).to.have.property('task_id');",
              "  pm.expect(j).to.have.property('task_description');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "04 Step",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"action_type\": \"{{action_type}}\",\n  \"reasoning\": \"postman validation run\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/step",
          "host": ["{{base_url}}"],
          "path": ["step"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const j = pm.response.json();",
              "pm.test('Step payload shape', function () {",
              "  pm.expect(j).to.have.property('observation');",
              "  pm.expect(j).to.have.property('reward');",
              "  pm.expect(j).to.have.property('done');",
              "  pm.expect(j).to.have.property('info');",
              "  pm.expect(j).to.have.property('score');",
              "  pm.expect(j).to.have.property('cumulative_reward');",
              "});",
              "pm.test('Score in [0,1]', function () {",
              "  pm.expect(j.score).to.be.at.least(0);",
              "  pm.expect(j.score).to.be.at.most(1);",
              "});",
              "pm.test('Done is boolean', function () {",
              "  pm.expect(typeof j.done).to.eql('boolean');",
              "});"
            ]
          }
        }
      ]
    },
